{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Quota Bar",
  "version": "0.9.0",
  "identifier": "app.codexquotabar.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm build:web -- --watch",
    "beforeBuildCommand": "pnpm build:web"
  },
  "app": {
    "windows": [
      {
        "label": "taskbar",
        "title": "",
        "url": "index.html",
        "width": 218,
        "height": 42,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false
      },
      {
        "label": "detail",
        "title": "Codex Quota Bar",
        "url": "index.html",
        "width": 520,
        "height": 650,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "menu",
        "title": "Codex Quota Bar Menu",
        "url": "index.html",
        "width": 180,
        "height": 164,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "Codex Quota Bar Settings",
        "url": "index.html",
        "width": 440,
        "height": 680,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:" }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Codex 5h and 7d quota in the Windows taskbar",
    "windows": { "wix": { "language": ["zh-CN", "en-US"] } }
  }
}
